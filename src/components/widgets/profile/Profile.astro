---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../../config";
import { url } from "../../../utils/url-utils";
import Image from "../../atoms/Image/Image.astro";
import TypewriterText from "../../atoms/typewriter-text/TypewriterText.astro";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
---

<div class="card-base p-3">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa7-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <Image
            src={profileConfig.avatar || ""}
            alt="Profile Image of the Author"
            class="mx-auto lg:w-full h-full lg:mt-0"
            loading="eager"
            fetchpriority="high"
        />
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{profileConfig.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        
        <div class="text-center text-neutral-400 mb-2.5 transition">
            {profileConfig.typewriter?.enable ? (
                <TypewriterText 
                    text={profileConfig.bio || ""}
                    speed={profileConfig.typewriter.speed}
                    class="inline-block"
                />
            ) : (
                profileConfig.bio
            )}
        </div>
        
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {profileConfig.links.length > 1 && profileConfig.links.map(item =>
                <a rel="me" aria-label={item.name} href={item.url} target="_blank" 
                   class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                    <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                </a>
            )}
            {profileConfig.links.length == 1 && 
                <a rel="me" aria-label={profileConfig.links[0].name} href={profileConfig.links[0].url} target="_blank"
                   class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                    <Icon name={profileConfig.links[0].icon} class="text-[1.5rem]"></Icon>
                    {profileConfig.links[0].name}
                </a>
            }
        </div>
        
        <div class="umami-stats-container hidden" data-umami-stats>
            <hr class="my-2 border-t border-dashed border-black/10 dark:border-white/10 transition-colors duration-150" />
            <div class="flex justify-center items-center gap-3 mt-2 transition-colors duration-150">
                <div class="flex items-center gap-1.5 text-sm text-50">
                    <Icon name="fa7-solid:eye" class="text-sm align-middle" />
                    <span class="font-medium site-stats-display">{i18n(I18nKey.profileStatsLoading)}</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script is:inline define:vars={{
    profileStatsPageViews: i18n(I18nKey.profileStatsPageViews),
    profileStatsVisits: i18n(I18nKey.profileStatsVisits)
}}>
    try {
        function formatCount(n) {
            if (n >= 10000) return (n / 10000).toFixed(1).replace(/\.0$/, '') + 'w';
            if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
            return String(n);
        }

        function generateStatsText(pageViews, visits) {
            return profileStatsPageViews + ' ' + formatCount(pageViews) + ' \u00B7 ' + profileStatsVisits + ' ' + formatCount(visits);
        }

        function updateAllSiteStats(pageViews, visits) {
            document.querySelectorAll('.site-stats-display').forEach(function(el) {
                el.textContent = generateStatsText(pageViews, visits);
            });
        }

        function showAllStatsContainers() {
            document.querySelectorAll('[data-umami-stats]').forEach(function(container) {
                container.classList.remove('hidden');
            });
        }

        function hideAllStatsContainers() {
            document.querySelectorAll('[data-umami-stats]').forEach(function(container) {
                container.classList.add('hidden');
            });
        }

        var _profileStatsRetryCount = 0;

        async function fetchSiteStats() {
            if (!window.oddmisc || typeof window.oddmisc.getSiteStats !== 'function') {
                _profileStatsRetryCount++;
                if (_profileStatsRetryCount <= 2) {
                    setTimeout(fetchSiteStats, 600);
                } else {
                    hideAllStatsContainers();
                }
                return;
            }

            try {
                var stats = await window.oddmisc.getSiteStats();
                var pageViews = stats.pageviews || 0;
                var visits = stats.visits || 0;

                if (pageViews === 0 && visits === 0) {
                    hideAllStatsContainers();
                    return;
                }

                showAllStatsContainers();
                updateAllSiteStats(pageViews, visits);
            } catch (error) {
                hideAllStatsContainers();
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', fetchSiteStats);
        } else {
            fetchSiteStats();
        }

        document.addEventListener('astro:page-load', fetchSiteStats);
    } catch (e) {
        var containers = document.querySelectorAll('[data-umami-stats]');
        containers.forEach(function(c) { c.classList.add('hidden'); });
    }
</script>