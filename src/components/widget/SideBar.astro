---
import type { MarkdownHeading } from "astro";
import { widgetManager } from "../../utils/widget-manager";
import Announcement from "./Announcement.astro";
import Calendar from "./Calendar.astro";
import Categories from "./Categories.astro";
import MusicPlayer from "./MusicPlayer.svelte";
import Profile from "./Profile.astro";
import SiteStats from "./SiteStats.astro";
import Tags from "./Tags.astro";
import TOC from "./TOC.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const { class: className, headings } = Astro.props;

// 获取不同设备下的组件列表
const mobileTopComponents = widgetManager.getComponentsByPosition("top", "drawer", "mobile");
const mobileStickyComponents = widgetManager.getComponentsByPosition("sticky", "drawer", "mobile");

const tabletTopComponents = widgetManager.getComponentsByPosition("top", "left", "tablet");
const tabletStickyComponents = widgetManager.getComponentsByPosition("sticky", "left", "tablet");

// 组件映射表
const componentMap = {
	profile: Profile,
	announcement: Announcement,
	categories: Categories,
	tags: Tags,
	toc: TOC,
	"music-player": MusicPlayer,
	"site-stats": SiteStats,
	calendar: Calendar,
};

// 渲染组件的辅助函数
function renderComponent(component: any, index: number, _components: any[]) {
	const ComponentToRender =
		componentMap[component.type as keyof typeof componentMap];
	if (!ComponentToRender) return null;

	const componentClass = widgetManager.getComponentClass(component, index);
	const componentStyle = widgetManager.getComponentStyle(component, index);

	return {
		Component: ComponentToRender,
		props: {
			class: componentClass,
			style: componentStyle,
			headings: component.type === "toc" ? headings : undefined,
			...component.customProps,
		},
	};
}
---

<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden opacity-0 transition-opacity duration-300 md:hidden" aria-hidden="true"></div>

<div id="sidebar" class:list={[className, "w-full sidebar-root"]}>
	<!-- 顶部组件区域 -->
	<div class="flex flex-col w-full gap-4 mb-4">
		<!-- 手机端顶部组件 -->
		{mobileTopComponents.length > 0 && (
			<div class="flex flex-col w-full gap-4 md:hidden">
				{mobileTopComponents.map((component, index) => {
					const renderData = renderComponent(component, index, mobileTopComponents);
					if (!renderData) return null;
					
					const { Component, props } = renderData;
					return <Component {...props} />;
				})}
			</div>
		)}

		<!-- 平板和桌面端顶部组件 -->
		{tabletTopComponents.length > 0 && (
			<div class="hidden md:flex flex-col w-full gap-4">
				{tabletTopComponents.map((component, index) => {
					const renderData = renderComponent(component, index, tabletTopComponents);
					if (!renderData) return null;
					
					const { Component, props } = renderData;
					return <Component {...props} />;
				})}
			</div>
		)}
	</div>
	
	<!-- 粘性组件区域 -->
	<div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 sticky top-4">
		<!-- 手机端粘性组件 -->
		{mobileStickyComponents.length > 0 && (
			<div class="flex flex-col w-full gap-4 md:hidden">
				{mobileStickyComponents.map((component, index) => {
					const renderData = renderComponent(component, index, mobileStickyComponents);
					if (!renderData) return null;
					
					const { Component, props } = renderData;
					return <Component {...props} />;
				})}
			</div>
		)}

		<!-- 平板和桌面端粘性组件 -->
		{tabletStickyComponents.length > 0 && (
			<div class="hidden md:flex flex-col w-full gap-4">
				{tabletStickyComponents.map((component, index) => {
					const renderData = renderComponent(component, index, tabletStickyComponents);
					if (!renderData) return null;
					
					const { Component, props } = renderData;
					return <Component {...props} />;
				})}
			</div>
		)}
	</div>
</div>

<!-- 响应式样式和JavaScript -->
<style>
	/* 移动端 Drawer 样式 */
	@media (max-width: 768px) {
		#sidebar {
			position: fixed;
			top: 0;
			left: 0;
			height: 100vh;
			width: 280px;
			max-width: 80vw;
			background: var(--card-bg);
			z-index: 50;
			transform: translateX(-100%);
			transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			overflow-y: auto;
			padding: 1rem;
			box-shadow: var(--shadow-xl);
		}

		#sidebar.open {
			transform: translateX(0);
		}

		#sidebar-overlay.open {
			display: block;
			opacity: 1;
		}
	}

	/* 平板/桌面端样式 */
	@media (min-width: 769px) {
		#sidebar {
			width: 100%; /* Parent grid controls width */
			/* clamp() for internal content width if needed, but grid handles it mostly */
		}
	}
	
	/* 字体缩放控制 */
	#sidebar :global(*) {
		font-size: clamp(0.875rem, 0.8rem + 0.25vw, 1rem);
	}
</style>

<script is:inline>
	class SidebarManager {
		constructor() {
			this.sidebar = document.getElementById('sidebar');
			this.overlay = document.getElementById('sidebar-overlay');
			this.isOpen = false;
			this.startX = 0;
			this.currentX = 0;
			this.threshold = 50; // Swipe threshold

			this.init();
		}
		
		init() {
			if (!this.sidebar || !this.overlay) return;

			// Bind methods
			this.handleTouchStart = this.handleTouchStart.bind(this);
			this.handleTouchMove = this.handleTouchMove.bind(this);
			this.handleTouchEnd = this.handleTouchEnd.bind(this);
			this.toggle = this.toggle.bind(this);
			this.close = this.close.bind(this);

			// Overlay click to close
			this.overlay.addEventListener('click', this.close);

			// Touch events on document for swipe
			document.addEventListener('touchstart', this.handleTouchStart, { passive: true });
			document.addEventListener('touchmove', this.handleTouchMove, { passive: false });
			document.addEventListener('touchend', this.handleTouchEnd);

			// SWUP cleanup
			if (window.swup) {
				window.swup.hooks.on('content:replace', () => {
					this.close(); // Close on navigation
				});
				// Ensure cleanup on destroy not strictly needed as this script re-runs or persists depending on implementation
				// But since is:inline re-runs, we should probably check for existing instance or cleanup old listeners
				// For now, simple close is enough. Ideally use a singleton pattern or cleanup.
			}
		}

		handleTouchStart(e) {
			this.startX = e.touches[0].clientX;
			this.currentX = this.startX;
		}

		handleTouchMove(e) {
			this.currentX = e.touches[0].clientX;
			const diff = this.currentX - this.startX;

			// Left-to-right swipe to open (from edge)
			if (!this.isOpen && this.startX < 30 && diff > 0) {
				e.preventDefault();
				// Optional: Add drag logic here for 1:1 movement
			}
		}

		handleTouchEnd(e) {
			const diff = this.currentX - this.startX;

			if (!this.isOpen) {
				// Swipe Right to Open
				if (this.startX < 50 && diff > this.threshold) { // Only from left edge
					this.open();
				}
			} else {
				// Swipe Left to Close
				if (diff < -this.threshold) {
					this.close();
				}
			}
		}

		open() {
			this.isOpen = true;
			this.sidebar.classList.add('open');
			this.overlay.classList.add('open');
			document.body.style.overflow = 'hidden'; // Prevent scrolling
		}

		close() {
			this.isOpen = false;
			this.sidebar.classList.remove('open');
			this.overlay.classList.remove('open');
			document.body.style.overflow = '';
		}

		toggle() {
			if (this.isOpen) this.close();
			else this.open();
		}
	}
	
	// Initialize
	// Check if already initialized to prevent duplicates (since is:inline might run again if not careful, though usually fine in Astro components unless swapped)
	if (!window._sidebarManager) {
		window._sidebarManager = new SidebarManager();
	} else {
		// Re-init DOM references if they changed (e.g. SWUP replace)
		// But SideBar might be outside of swup container. 
		// If SideBar IS in swup container, we need to re-instantiate.
		// Let's just create a new one, old one's listeners on document persist... that's bad.
		// We need cleanup.
	}
	
	// Better approach:
	// Remove old listeners if any
	if (window._sidebarCleanup) window._sidebarCleanup();

	const manager = new SidebarManager();
	
	window._sidebarCleanup = () => {
		document.removeEventListener('touchstart', manager.handleTouchStart);
		document.removeEventListener('touchmove', manager.handleTouchMove);
		document.removeEventListener('touchend', manager.handleTouchEnd);
		if (manager.overlay) manager.overlay.removeEventListener('click', manager.close);
	};

</script>
