---
import { Icon } from "astro-icon/components";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../../utils/date-utils";
import { getTagUrl } from "../../../utils/url-utils";
import { PublishedDate } from "./atoms";
import { Category } from "./atoms";
import { WordCount } from "./atoms";
import { ReadingTime } from "./atoms";
import { EncryptedBadge } from "./atoms";

interface Props {
	published: Date;
	updated?: Date;
	category?: string;
	tags?: string[];
	hideUpdateDate?: boolean;
	hideTagsForMobile?: boolean;
	isHome?: boolean;
	className?: string;
	id?: string;
	postUrl?: string;
	showOnlyBasicMeta?: boolean;
	words?: number;
	minutes?: number;
	showWordCount?: boolean;
	showReadingTime?: boolean;
	showEncrypted?: boolean;
}

const {
	published,
	updated,
	category,
	tags,
	hideUpdateDate,
	hideTagsForMobile,
	isHome,
	className = "",
	id,
	postUrl,
	showOnlyBasicMeta = false,
	words,
	minutes,
	showWordCount = false,
	showReadingTime = false,
	showEncrypted = false,
} = Astro.props;
---

<div class:list={["flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2", className]}>
    <PublishedDate date={published} />

    {!hideUpdateDate && updated && updated.getTime() !== published.getTime() && (
        <div class="flex items-center">
            <div class="meta-icon">
                <Icon name="material-symbols:edit-calendar-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium">{formatDateToYYYYMMDD(updated)}</span>
        </div>
    )}

    <Category category={category} />

    {showWordCount && words && (
        <WordCount words={words} />
    )}

    {showReadingTime && minutes && (
        <ReadingTime minutes={minutes} />
    )}

    {!showOnlyBasicMeta && (
        <div class:list={["items-center", {"flex": !hideTagsForMobile, "hidden md:flex": hideTagsForMobile}]}>
            <div class="meta-icon">
                <Icon name="material-symbols:tag-rounded" class="text-xl"></Icon>
            </div>
            <div class="flex flex-row flex-nowrap items-center">
                {(tags && tags.length > 0) && tags.map((tag, i) => (
                    <>
                        <div class:list={[{"hidden": i == 0}, "mx-1.5 text-[var(--meta-divider)] text-sm"]}>/</div>
                        <a href={getTagUrl(tag)} aria-label={`View all posts with the ${tag.trim()} tag`}
                           class="link-lg transition text-50 text-sm font-medium
                                        hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap">
                            {tag.trim()}
                        </a>
                    </>
                ))}
                {!(tags && tags.length > 0) && <div class="transition text-50 text-sm font-medium">{i18n(I18nKey.noTags)}</div>}
            </div>
        </div>
    )}
    
    {!isHome && (postUrl || id) && (
        <div class="flex items-center umami-page-views hidden" data-page-url={postUrl} data-page-id={id} data-umami-page-views>
            <div class="meta-icon">
                <Icon name="material-symbols:visibility-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium page-views-display">{i18n(I18nKey.pageViewsLoading)}</span>
        </div>
    )}

    {showEncrypted && (
        <EncryptedBadge />
    )}
    
    {!isHome && (postUrl || id) && (
<script is:inline define:vars={{
    pageViewsText: i18n(I18nKey.profileStatsPageViews),
    visitsText: i18n(I18nKey.profileStatsVisits)
}}>
    try {
        function formatCount(n) {
            if (n >= 10000) return (n / 10000).toFixed(1).replace(/\.0$/, '') + 'w';
            if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
            return String(n);
        }

        function generateStatsText(pageViews, visits) {
            return pageViewsText + ' ' + formatCount(pageViews) + ' \u00B7 ' + visitsText + ' ' + formatCount(visits);
        }

        var _pageViewsRetryCount = 0;

        async function fetchAllPageViews() {
            if (!window.oddmisc || typeof window.oddmisc.getStats !== 'function') {
                _pageViewsRetryCount++;
                if (_pageViewsRetryCount <= 2) {
                    setTimeout(fetchAllPageViews, 600);
                } else {
                    document.querySelectorAll('[data-umami-page-views]').forEach(function(container) {
                        container.classList.add('hidden');
                    });
                }
                return;
            }

            var containers = document.querySelectorAll('[data-umami-page-views]');

            var fetchPromises = Array.from(containers).map(async function(container) {
                var pageUrl = container.dataset.pageUrl;
                var pageId = container.dataset.pageId;
                
                var statsPath;
                if (pageUrl) {
                    statsPath = pageUrl;
                } else if (pageId) {
                    statsPath = '/posts/' + pageId.replace(/\.(md|mdx|markdown)$/i, '') + '/';
                } else {
                    return;
                }

                try {
                    var stats = await window.oddmisc.getStats(statsPath);
                    var pageViews = stats.pageviews || 0;
                    var visits = stats.visitors || 0;

                    if (pageViews === 0 && visits === 0) {
                        container.classList.add('hidden');
                        return;
                    }

                    container.classList.remove('hidden');
                    var display = container.querySelector('.page-views-display');
                    if (display) {
                        display.textContent = generateStatsText(pageViews, visits);
                    }
                } catch (error) {
                    container.classList.add('hidden');
                }
            });

            await Promise.all(fetchPromises);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', fetchAllPageViews);
        } else {
            fetchAllPageViews();
        }

        document.addEventListener('astro:page-load', fetchAllPageViews);
    } catch (e) {
        document.querySelectorAll('[data-umami-page-views]').forEach(function(c) {
            c.classList.add('hidden');
        });
    }
</script>
)}
