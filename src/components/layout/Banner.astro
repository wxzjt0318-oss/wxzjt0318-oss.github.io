---
/**
 * Banner 组件 - 高性能版本
 * 
 * 核心优化策略（参考Mizuki原始实现）：
 * 1. template预存帧 - 避免动态创建DOM
 * 2. 帧缓存机制 - 切换时直接使用缓存HTML
 * 3. 双rAF同步 - 确保动画流畅
 * 4. 页面可见性API - 后台暂停节省资源
 * 5. 鼠标悬停暂停 - 提升用户体验
 */

import TypewriterText from "@components/atoms/typewriter-text/TypewriterText.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import { BANNER_HEIGHT_EXTEND } from "../../constants/constants";

interface Props {
	mobileNonHomeBannerClass?: string;
	showTextOverlay?: boolean;
	overlayTitle?: string;
	overlaySubtitle?: string | string[];
	typewriter?: boolean;
	showWave?: boolean;
}

const {
	mobileNonHomeBannerClass = "",
	showTextOverlay = false,
	overlayTitle = siteConfig.banner.homeText?.title,
	overlaySubtitle = siteConfig.banner.homeText?.subtitle,
	typewriter = siteConfig.banner.homeText?.typewriter?.enable ?? false,
	showWave = siteConfig.banner.waves?.enable ?? true,
} = Astro.props;

const isCarouselEnabled = siteConfig.banner.carousel?.enable;
const carouselIntervalMs = Math.max(
	(siteConfig.banner.carousel?.interval || 6) * 1000,
	1500,
);
const fadeMs = Math.min(Math.max(Math.round(carouselIntervalMs * 0.4), 500), 1500);
const kbDurationMs = carouselIntervalMs + fadeMs;

const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const bannerSrc = siteConfig.banner.src;
let fallbackDesktopImages: string | string[];
let fallbackMobileImages: string | string[];

if (typeof bannerSrc === 'string' || Array.isArray(bannerSrc)) {
	fallbackDesktopImages = bannerSrc;
	fallbackMobileImages = bannerSrc;
} else {
	fallbackDesktopImages = bannerSrc.desktop || [];
	fallbackMobileImages = bannerSrc.mobile || [];
}
---

<div
	id="banner-wrapper"
	class={`absolute z-10 w-full transition duration-700 overflow-hidden ${mobileNonHomeBannerClass}`}
	style={`top: -${BANNER_HEIGHT_EXTEND}vh`}
>
	<!-- 骨架屏占位 -->
	<div id="banner-skeleton" class="absolute inset-0 z-0 banner-skeleton">
		<div class="banner-loading-text absolute inset-0 flex items-center justify-center">
			<div class="text-white/60 text-lg animate-pulse">加载中...</div>
		</div>
	</div>
	
	<!-- 轮播容器 -->
	<div
		id="banner-carousel"
		class="relative h-full w-full"
		data-carousel-interval={carouselIntervalMs}
		data-fade-ms={fadeMs}
		data-position={siteConfig.banner.position}
	>
		<!-- 移动端槽位 -->
		<div class="banner-image-slot-mobile absolute inset-0 block md:hidden" style="opacity: 0;"></div>
		<!-- 桌面端槽位 -->
		<div class="banner-image-slot-desktop absolute inset-0 hidden md:block" style="opacity: 0;"></div>
	</div>

	{siteConfig.banner.homeText?.enable && (
		<div class={`banner-text-overlay absolute inset-0 z-20 flex items-center justify-center ${!showTextOverlay ? "hidden" : ""}`}>
			<div class="w-4/5 lg:w-3/4 text-center mb-0">
				<div class="flex flex-col">
					{overlayTitle && (
						<h1 class="banner-title text-6xl lg:text-8xl text-white drop-shadow-lg mb-2 lg:mb-4">
							{overlayTitle}
						</h1>
					)}
					{overlaySubtitle && (
						<h2 class="banner-subtitle text-xl lg:text-3xl text-white/90 drop-shadow-md">
							<span class="inline-block min-h-[1.2em]">
								{typewriter && Array.isArray(overlaySubtitle) ? (
									<TypewriterText
										text={overlaySubtitle}
										speed={siteConfig.banner.homeText?.typewriter?.speed}
										deleteSpeed={siteConfig.banner.homeText?.typewriter?.deleteSpeed}
										pauseTime={siteConfig.banner.homeText?.typewriter?.pauseTime}
									/>
								) : Array.isArray(overlaySubtitle) ? (
									overlaySubtitle[0]
								) : (
									overlaySubtitle
								)}
							</span>
						</h2>
					)}
				</div>
			</div>
		</div>
	)}

	{showWave && (
		<div
			class="waves absolute -bottom-[1px] h-[10vh] max-h-[9.375rem] min-h-[3.125rem] w-full md:h-[15vh]"
			id="header-waves"
			style="transform: translateZ(0); will-change: fill;"
		>
			<svg
				class="waves"
				xmlns="http://www.w3.org/2000/svg"
				xmlns:xlink="http://www.w3.org/1999/xlink"
				viewBox="0 20 150 32"
				preserveAspectRatio="none"
				shape-rendering="auto"
				style="transform: translateZ(0); backface-visibility: hidden;"
			>
				<defs>
					<path
						id="gentle-wave"
						d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v48h-352z"
					>
					</path>
				</defs>
				<g class="parallax" style="transform: translateZ(0);">
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="0"
						class="opacity-25 fill-[var(--page-bg)]"
						style="animation-delay: -2s; animation-duration: 7s; will-change: transform;"
					></use>
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="3"
						class="opacity-50 fill-[var(--page-bg)]"
						style="animation-delay: -3s; animation-duration: 10s; will-change: transform;"
					></use>
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="5"
						class="opacity-75 fill-[var(--page-bg)]"
						style="animation-delay: -4s; animation-duration: 13s; will-change: transform;"
					></use>
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="7"
						class="fill-[var(--page-bg)]"
						style="animation-delay: -5s; animation-duration: 20s; will-change: transform;"
					></use>
				</g>
			</svg>
		</div>
	)}

	{hasBannerCredit && (
		<a
			href={siteConfig.banner.credit.url}
			id="banner-credit"
			target="_blank"
			rel="noopener"
			aria-label="Visit image source"
			class:list={[
				"group onload-animation transition-all absolute flex justify-center items-center rounded-full px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9",
				{ "hover:pr-9 active:bg-black/80": hasBannerLink },
			]}
		>
			<Icon
				class="text-white/75 text-[1.25rem] mr-1"
				name="material-symbols:copyright-outline-rounded"
			/>
			<div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
			<Icon
				class:list={[
					"transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
					{ "group-hover:opacity-100": hasBannerLink },
				]}
				name="fa7-solid:arrow-up-right-from-square"
			>
			</Icon>
		</a>
	)}
</div>

{isCarouselEnabled && (
	<Fragment set:html={`<style>
		@keyframes bannerKenBurns {
			0% { transform: scale(1.03); }
			100% { transform: scale(1.13); }
		}
		.banner-kb {
			animation: bannerKenBurns ${kbDurationMs}ms ease-out forwards;
		}
	</style>`} />
)}

<script is:inline data-swup-ignore-script define:vars={{ 
	isCarouselEnabled, 
	carouselIntervalMs, 
	fadeMs,
	fallbackDesktopImages,
	fallbackMobileImages
}}>
(function initHighPerfBanner() {
	'use strict';
	
	var container = document.getElementById('banner-carousel');
	var skeleton = document.getElementById('banner-skeleton');
	if (!container) return;

	var position = container.dataset.position || 'center';
	var interval = parseInt(container.dataset.carouselInterval || '6000', 10);
	var FADE_MS = parseInt(container.dataset.fadeMs || '1500', 10);

	var desktopImages = [];
	var mobileImages = [];
	var carouselTimer = null;
	var isPaused = false;
	var isCrossfading = { mobile: false, desktop: false };
	var preloadedImages = { desktop: [], mobile: [] };
	var apiCalled = false;

	// 清理上一次遗留
	if (window.__bannerCarouselCleanup) {
		window.__bannerCarouselCleanup();
		window.__bannerCarouselCleanup = null;
	}

	// 帧缓存 - 核心优化：避免每次切换重建DOM
	if (!window.__bannerCarouselFrames) {
		window.__bannerCarouselFrames = {};
	}
	if (!window.__bannerCarouselIndex) {
		window.__bannerCarouselIndex = { mobile: 0, desktop: 0 };
	}

	function hideSkeleton() {
		if (skeleton) {
			skeleton.style.transition = 'opacity 0.4s ease-out';
			skeleton.style.opacity = '0';
			setTimeout(function() {
				skeleton.style.display = 'none';
			}, 400);
		}
	}

	function showSkeletonError(message) {
		if (skeleton) {
			var loadingText = skeleton.querySelector('.banner-loading-text');
			if (loadingText) {
				loadingText.innerHTML = '<div class="text-white/40 text-sm">' + (message || '图片加载失败') + '</div>';
			}
		}
	}

	function isMobile() {
		return window.innerWidth < 768;
	}

	function preloadImageAsBlob(src) {
		return new Promise(function(resolve, reject) {
			fetch(src, { mode: 'cors', credentials: 'omit' })
				.then(function(response) {
					if (!response.ok) {
						throw new Error('Network response was not ok');
					}
					return response.blob();
				})
				.then(function(blob) {
					var blobUrl = URL.createObjectURL(blob);
					resolve(blobUrl);
				})
				.catch(function(error) {
					console.warn('Failed to preload image as blob:', src, error);
					reject(src);
				});
		});
	}

	async function preloadAllImages(urls, type) {
		var promises = urls.map(async function(url, index) {
			try {
				var blobUrl = await preloadImageAsBlob(url);
				preloadedImages[type][index] = blobUrl;
				return { success: true, src: blobUrl, originalSrc: url, index: index };
			} catch (error) {
				preloadedImages[type][index] = url;
				return { success: false, src: url, originalSrc: url, index: index };
			}
		});
		return Promise.all(promises);
	}

	function createImageHTML(src, index) {
		var imgClass = 'object-cover h-full w-full';
		return '<img alt="Banner image ' + (index + 1) + '" class="' + imgClass + '" src="' + src + '" style="object-position: ' + position + ';" />';
	}

	function collectFrames(images) {
		var frames = [];
		for (var i = 0; i < images.length; i++) {
			frames.push(createImageHTML(images[i], i));
		}
		return frames;
	}

	function applyInitialKB(slotClass) {
		var slot = container.querySelector('.' + slotClass);
		if (!slot) return;
		slot.classList.remove('banner-kb');
		void slot.offsetWidth;
		slot.classList.add('banner-kb');
	}

	function cleanupOrphanedLayers(slotClass, currentSlot) {
		var allSlots = container.querySelectorAll('.' + slotClass);
		for (var i = 0; i < allSlots.length; i++) {
			if (allSlots[i] !== currentSlot && allSlots[i].parentNode) {
				allSlots[i].parentNode.removeChild(allSlots[i]);
			}
		}
	}

	function crossfadeToIndex(slotClass, type, targetIndex) {
		var frames = window.__bannerCarouselFrames[slotClass];
		if (!frames || frames.length <= 1) return;
		if (isCrossfading[type]) return;

		var oldSlot = container.querySelector('.' + slotClass);
		if (!oldSlot) return;

		isCrossfading[type] = true;
		window.__bannerCarouselIndex[type] = targetIndex;

		cleanupOrphanedLayers(slotClass, oldSlot);

		var newSlot = document.createElement('div');
		var baseClass = oldSlot.className.replace(/\bbanner-kb\b/g, '').trim();
		newSlot.className = baseClass;
		newSlot.style.opacity = '0';
		newSlot.style.transition = 'opacity ' + FADE_MS + 'ms ease-in-out';
		newSlot.innerHTML = frames[targetIndex];
		oldSlot.parentNode.insertBefore(newSlot, oldSlot.nextSibling);

		// 双rAF确保动画同步
		requestAnimationFrame(function() {
			requestAnimationFrame(function() {
				newSlot.style.opacity = '1';
				newSlot.classList.add('banner-kb');
			});
		});

		setTimeout(function() {
			if (oldSlot.parentNode) {
				oldSlot.parentNode.removeChild(oldSlot);
			}
			newSlot.style.transition = '';
			isCrossfading[type] = false;
		}, FADE_MS + 50);
	}

	function crossfade(slotClass, type) {
		var frames = window.__bannerCarouselFrames[slotClass];
		if (!frames || frames.length <= 1) return;
		var currentIndex = window.__bannerCarouselIndex[type];
		var nextIndex = (currentIndex + 1) % frames.length;
		crossfadeToIndex(slotClass, type, nextIndex);
	}

	function startCarousel() {
		stopCarousel();
		if (isPaused) return;

		applyInitialKB('banner-image-slot-mobile');
		applyInitialKB('banner-image-slot-desktop');

		carouselTimer = setInterval(function() {
			if (!isPaused) {
				crossfade('banner-image-slot-mobile', 'mobile');
				crossfade('banner-image-slot-desktop', 'desktop');
			}
		}, interval);
	}

	function stopCarousel() {
		if (carouselTimer !== null) {
			clearInterval(carouselTimer);
			carouselTimer = null;
		}
	}

	// 页面可见性API
	var visibilityHandler = function() {
		if (document.hidden) {
			stopCarousel();
		} else if (!isPaused) {
			startCarousel();
		}
	};
	document.addEventListener('visibilitychange', visibilityHandler);

	// 触摸事件
	var touchStartX = 0;
	var touchStartY = 0;
	var isSwiping = false;

	var onTouchStart = function(e) {
		touchStartX = e.touches[0].clientX;
		touchStartY = e.touches[0].clientY;
		isSwiping = false;
		isPaused = true;
		stopCarousel();
	};

	var onTouchMove = function(e) {
		if (!touchStartX || !touchStartY) return;
		var diffX = Math.abs(e.touches[0].clientX - touchStartX);
		var diffY = Math.abs(e.touches[0].clientY - touchStartY);
		if (diffX > diffY && diffX > 30) {
			isSwiping = true;
			e.preventDefault();
		}
	};

	var onTouchEnd = function(e) {
		if (!touchStartX || !touchStartY || !isSwiping) {
			isPaused = false;
			startCarousel();
			return;
		}

		var endX = e.changedTouches[0].clientX;
		var diffX = touchStartX - endX;
		var type = isMobile() ? 'mobile' : 'desktop';
		var slotClass = isMobile() ? 'banner-image-slot-mobile' : 'banner-image-slot-desktop';
		var frames = window.__bannerCarouselFrames[slotClass];
		var current = window.__bannerCarouselIndex[type];

		if (frames && frames.length > 1 && Math.abs(diffX) > 50) {
			var nextIndex = diffX > 0
				? (current + 1) % frames.length
				: (current - 1 + frames.length) % frames.length;
			crossfadeToIndex(slotClass, type, nextIndex);
		}

		touchStartX = 0;
		touchStartY = 0;
		isSwiping = false;
		isPaused = false;
		startCarousel();
	};

	// 鼠标事件
	var onMouseEnter = function() {
		isPaused = true;
		stopCarousel();
	};

	var onMouseLeave = function() {
		isPaused = false;
		startCarousel();
	};

	function showFirstImage() {
		var type = isMobile() ? 'mobile' : 'desktop';
		var images = type === 'mobile' 
			? (preloadedImages.mobile.length > 0 ? preloadedImages.mobile : mobileImages)
			: (preloadedImages.desktop.length > 0 ? preloadedImages.desktop : desktopImages);
		var slotClass = type === 'mobile' ? 'banner-image-slot-mobile' : 'banner-image-slot-desktop';
		
		if (images.length === 0) {
			hideSkeleton();
			showSkeletonError('暂无图片');
			return;
		}

		var slot = container.querySelector('.' + slotClass);
		if (!slot) return;

		slot.innerHTML = window.__bannerCarouselFrames[slotClass][0];
		slot.style.opacity = '1';
		
		var img = slot.querySelector('img');
		if (img && img.complete) {
			hideSkeleton();
		} else if (img) {
			img.onload = function() {
				hideSkeleton();
			};
			img.onerror = function() {
				console.warn('First banner image failed to load:', images[0]);
				hideSkeleton();
				showSkeletonError('首张图片加载失败');
			};
		} else {
			hideSkeleton();
		}
	}

	async function fetchBannerImages() {
		if (apiCalled) {
			return;
		}
		apiCalled = true;

		var imageCount = 6;
		
		try {
			var response = await fetch('/api/banner-images.json?count=' + imageCount);
			
			if (response.ok) {
				var data = await response.json();
				
				if (data.desktop && data.desktop.length > 0) {
					desktopImages = data.desktop;
				}
				if (data.mobile && data.mobile.length > 0) {
					mobileImages = data.mobile;
				}
			} else {
				throw new Error('API response not ok');
			}
		} catch (error) {
			console.warn('Failed to fetch banner images from API, using fallback:', error);
			desktopImages = Array.isArray(fallbackDesktopImages) ? fallbackDesktopImages : [fallbackDesktopImages];
			mobileImages = Array.isArray(fallbackMobileImages) ? fallbackMobileImages : [fallbackMobileImages];
		}

		if (desktopImages.length === 0 && Array.isArray(fallbackDesktopImages)) {
			desktopImages = fallbackDesktopImages;
		}
		if (mobileImages.length === 0 && Array.isArray(fallbackMobileImages)) {
			mobileImages = fallbackMobileImages;
		}

		await Promise.all([
			preloadAllImages(desktopImages, 'desktop'),
			preloadAllImages(mobileImages, 'mobile')
		]);

		var finalDesktopImages = preloadedImages.desktop.length > 0 ? preloadedImages.desktop : desktopImages;
		var finalMobileImages = preloadedImages.mobile.length > 0 ? preloadedImages.mobile : mobileImages;

		window.__bannerCarouselFrames['banner-image-slot-mobile'] = collectFrames(finalMobileImages);
		window.__bannerCarouselFrames['banner-image-slot-desktop'] = collectFrames(finalDesktopImages);

		showFirstImage();
		
		if (isCarouselEnabled && (desktopImages.length > 1 || mobileImages.length > 1)) {
			startCarousel();
		}

		if ('ontouchstart' in window) {
			container.addEventListener('touchstart', onTouchStart, { passive: true });
			container.addEventListener('touchmove', onTouchMove, { passive: false });
			container.addEventListener('touchend', onTouchEnd, { passive: true });
		}
		container.addEventListener('mouseenter', onMouseEnter);
		container.addEventListener('mouseleave', onMouseLeave);
	}

	// 注册清理函数
	window.__bannerCarouselCleanup = function() {
		stopCarousel();
		document.removeEventListener('visibilitychange', visibilityHandler);
		if ('ontouchstart' in window) {
			container.removeEventListener('touchstart', onTouchStart);
			container.removeEventListener('touchmove', onTouchMove);
			container.removeEventListener('touchend', onTouchEnd);
		}
		container.removeEventListener('mouseenter', onMouseEnter);
		container.removeEventListener('mouseleave', onMouseLeave);
		isCrossfading = { mobile: false, desktop: false };
		
		// 释放Blob URL
		preloadedImages.desktop.forEach(function(url) {
			if (url && url.startsWith('blob:')) {
				URL.revokeObjectURL(url);
			}
		});
		preloadedImages.mobile.forEach(function(url) {
			if (url && url.startsWith('blob:')) {
				URL.revokeObjectURL(url);
			}
		});
		preloadedImages = { desktop: [], mobile: [] };
	};

	fetchBannerImages();
})();
</script>

<style>
	.banner-title {
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
		animation: fadeInUp 1s ease-out;
		font-weight: bold;
	}

	.banner-subtitle {
		text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.6);
		animation: fadeInUp 1s ease-out 0.3s both;
		min-height: 1.5em;
		line-height: 1.2;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.banner-skeleton {
		background: linear-gradient(
			90deg,
			var(--card-bg) 0%,
			var(--btn-hover-bg, rgba(0, 0, 0, 0.05)) 50%,
			var(--card-bg) 100%
		);
		background-size: 200% 100%;
		animation: bannerShimmer 1.5s ease-in-out infinite;
		transition: opacity 0.4s ease-out;
	}

	@keyframes bannerShimmer {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	:global(.dark) .banner-skeleton {
		background: linear-gradient(
			90deg,
			var(--card-bg) 0%,
			rgba(255, 255, 255, 0.05) 50%,
			var(--card-bg) 100%
		);
		background-size: 200% 100%;
	}

	.banner-loading-text {
		z-index: 1;
	}
</style>
