---
/**
 * Banner 组件 - 高性能版本
 * 支持：动态API获取图片、响应式图片、智能懒加载、图片缓存、失败重试、弱网络优化
 */

import TypewriterText from "@components/atoms/typewriter-text/TypewriterText.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import { BANNER_HEIGHT_EXTEND } from "../../constants/constants";

interface Props {
	mobileNonHomeBannerClass?: string;
	showTextOverlay?: boolean;
	overlayTitle?: string;
	overlaySubtitle?: string | string[];
	typewriter?: boolean;
	showWave?: boolean;
}

const {
	mobileNonHomeBannerClass = "",
	showTextOverlay = false,
	overlayTitle = siteConfig.banner.homeText?.title,
	overlaySubtitle = siteConfig.banner.homeText?.subtitle,
	typewriter = siteConfig.banner.homeText?.typewriter?.enable ?? false,
	showWave = siteConfig.banner.waves?.enable ?? true,
} = Astro.props;

const isCarouselEnabled = siteConfig.banner.carousel?.enable;
const carouselIntervalMs = Math.max(
	(siteConfig.banner.carousel?.interval || 6) * 1000,
	1500,
);
const fadeMs = Math.min(Math.max(Math.round(carouselIntervalMs * 0.4), 500), 1500);
const kbDurationMs = carouselIntervalMs + fadeMs;

const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const bannerSrc = siteConfig.banner.src;
let fallbackDesktopImages: string | string[];
let fallbackMobileImages: string | string[];

if (typeof bannerSrc === 'string' || Array.isArray(bannerSrc)) {
	fallbackDesktopImages = bannerSrc;
	fallbackMobileImages = bannerSrc;
} else {
	fallbackDesktopImages = bannerSrc.desktop || [];
	fallbackMobileImages = bannerSrc.mobile || [];
}
---

<div
	id="banner-wrapper"
	class={`absolute z-10 w-full transition duration-700 overflow-hidden ${mobileNonHomeBannerClass}`}
	style={`top: -${BANNER_HEIGHT_EXTEND}vh`}
>
	<!-- 骨架屏占位 -->
	<div id="banner-skeleton" class="absolute inset-0 z-0 banner-skeleton">
		<div class="banner-loading-text absolute inset-0 flex flex-col items-center justify-center">
			<div class="banner-spinner mb-3"></div>
			<div class="text-white/60 text-lg" id="banner-loading-status">加载中...</div>
			<div class="text-white/40 text-xs mt-1" id="banner-loading-progress"></div>
		</div>
	</div>
	
	<!-- 图片容器 -->
	<div
		id="banner-carousel"
		class="relative h-full w-full"
		data-carousel-interval={carouselIntervalMs}
		data-fade-ms={fadeMs}
		data-position={siteConfig.banner.position}
	>
	</div>

	{siteConfig.banner.homeText?.enable && (
		<div class={`banner-text-overlay absolute inset-0 z-20 flex items-center justify-center ${!showTextOverlay ? "hidden" : ""}`}>
			<div class="w-4/5 lg:w-3/4 text-center mb-0">
				<div class="flex flex-col">
					{overlayTitle && (
						<h1 class="banner-title text-6xl lg:text-8xl text-white drop-shadow-lg mb-2 lg:mb-4">
							{overlayTitle}
						</h1>
					)}
					{overlaySubtitle && (
						<h2 class="banner-subtitle text-xl lg:text-3xl text-white/90 drop-shadow-md">
							<span class="inline-block min-h-[1.2em]">
								{typewriter && Array.isArray(overlaySubtitle) ? (
									<TypewriterText
										text={overlaySubtitle}
										speed={siteConfig.banner.homeText?.typewriter?.speed}
										deleteSpeed={siteConfig.banner.homeText?.typewriter?.deleteSpeed}
										pauseTime={siteConfig.banner.homeText?.typewriter?.pauseTime}
									/>
								) : Array.isArray(overlaySubtitle) ? (
									overlaySubtitle[0]
								) : (
									overlaySubtitle
								)}
							</span>
						</h2>
					)}
				</div>
			</div>
		</div>
	)}

	{showWave && (
		<div
			class="waves absolute -bottom-[1px] h-[10vh] max-h-[9.375rem] min-h-[3.125rem] w-full md:h-[15vh]"
			id="header-waves"
			style="transform: translateZ(0); will-change: fill;"
		>
			<svg
				class="waves"
				xmlns="http://www.w3.org/2000/svg"
				xmlns:xlink="http://www.w3.org/1999/xlink"
				viewBox="0 20 150 32"
				preserveAspectRatio="none"
				shape-rendering="auto"
				style="transform: translateZ(0); backface-visibility: hidden;"
			>
				<defs>
					<path
						id="gentle-wave"
						d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v48h-352z"
					>
					</path>
				</defs>
				<g class="parallax" style="transform: translateZ(0);">
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="0"
						class="opacity-25 fill-[var(--page-bg)]"
						style="animation-delay: -2s; animation-duration: 7s; will-change: transform;"
					></use>
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="3"
						class="opacity-50 fill-[var(--page-bg)]"
						style="animation-delay: -3s; animation-duration: 10s; will-change: transform;"
					></use>
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="5"
						class="opacity-75 fill-[var(--page-bg)]"
						style="animation-delay: -4s; animation-duration: 13s; will-change: transform;"
					></use>
					<use
						xlink:href="#gentle-wave"
						x="48"
						y="7"
						class="fill-[var(--page-bg)]"
						style="animation-delay: -5s; animation-duration: 20s; will-change: transform;"
					></use>
				</g>
			</svg>
		</div>
	)}

	{hasBannerCredit && (
		<a
			href={siteConfig.banner.credit.url}
			id="banner-credit"
			target="_blank"
			rel="noopener"
			aria-label="Visit image source"
			class:list={[
				"group onload-animation transition-all absolute flex justify-center items-center rounded-full px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9",
				{ "hover:pr-9 active:bg-black/80": hasBannerLink },
			]}
		>
			<Icon
				class="text-white/75 text-[1.25rem] mr-1"
				name="material-symbols:copyright-outline-rounded"
			/>
			<div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
			<Icon
				class:list={[
					"transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
					{ "group-hover:opacity-100": hasBannerLink },
				]}
				name="fa7-solid:arrow-up-right-from-square"
			>
			</Icon>
		</a>
	)}
</div>

{isCarouselEnabled && (
	<Fragment set:html={`<style>
		@keyframes bannerKenBurns {
			0% { transform: scale(1.03); }
			100% { transform: scale(1.13); }
		}
		.banner-kb {
			animation: bannerKenBurns ${kbDurationMs}ms ease-out forwards;
		}
	</style>`} />
)}

<script is:inline data-swup-ignore-script define:vars={{ 
	isCarouselEnabled, 
	carouselIntervalMs, 
	fadeMs,
	fallbackDesktopImages,
	fallbackMobileImages
}}>
(function initHighPerfBanner() {
	'use strict';
	
	var container = document.getElementById('banner-carousel');
	var skeleton = document.getElementById('banner-skeleton');
	var loadingStatus = document.getElementById('banner-loading-status');
	var loadingProgress = document.getElementById('banner-loading-progress');
	if (!container) return;

	var position = container.dataset.position || 'center';
	var interval = parseInt(container.dataset.carouselInterval || '6000', 10);
	var FADE_MS = parseInt(container.dataset.fadeMs || '1500', 10);

	var desktopImages = [];
	var mobileImages = [];
	var loadedImages = { desktop: [], mobile: [] };
	var currentIndex = { desktop: 0, mobile: 0 };
	var isCrossfading = { desktop: false, mobile: false };
	var carouselTimer = null;
	var imageCache = new Map();
	var MAX_RETRIES = 3;
	var RETRY_DELAY = 1000;
	var LOAD_TIMEOUT = 15000;

	function updateLoadingStatus(status, progress) {
		if (loadingStatus) loadingStatus.textContent = status;
		if (loadingProgress) loadingProgress.textContent = progress || '';
	}

	function hideSkeleton() {
		if (skeleton) {
			skeleton.style.transition = 'opacity 0.5s ease';
			skeleton.style.opacity = '0';
			setTimeout(function() {
				skeleton.style.display = 'none';
			}, 500);
		}
	}

	function showSkeletonError(message, showRetry) {
		if (skeleton) {
			var loadingText = skeleton.querySelector('.banner-loading-text');
			if (loadingText) {
				var html = '<div class="text-white/40 text-sm mb-2">' + message + '</div>';
				if (showRetry) {
					html += '<button onclick="location.reload()" class="px-4 py-1 bg-white/20 hover:bg-white/30 rounded text-white/70 text-xs transition">重新加载</button>';
				}
				loadingText.innerHTML = html;
			}
		}
	}

	function isMobile() {
		return window.innerWidth < 768;
	}

	function getCachedImage(src) {
		if (imageCache.has(src)) {
			var cached = imageCache.get(src);
			if (cached.status === 'loaded') {
				return cached.blob;
			}
		}
		return null;
	}

	function setCachedImage(src, blob) {
		imageCache.set(src, { status: 'loaded', blob: blob, timestamp: Date.now() });
		if (imageCache.size > 20) {
			var oldestKey = imageCache.keys().next().value;
			imageCache.delete(oldestKey);
		}
	}

	function loadImageWithRetry(src, retryNum) {
		if (retryNum === undefined) retryNum = 0;
		
		return new Promise(function(resolve, reject) {
			var cached = getCachedImage(src);
			if (cached) {
				resolve(URL.createObjectURL(cached));
				return;
			}

			var timeoutId = setTimeout(function() {
				img.onload = null;
				img.onerror = null;
				if (retryNum < MAX_RETRIES) {
					console.warn('[Banner] Image timeout, retrying:', retryNum + 1, src);
					setTimeout(function() {
						loadImageWithRetry(src, retryNum + 1).then(resolve).catch(reject);
					}, RETRY_DELAY * (retryNum + 1));
				} else {
					reject(new Error('Image load timeout after ' + MAX_RETRIES + ' retries'));
				}
			}, LOAD_TIMEOUT);

			var img = new Image();
			img.crossOrigin = 'anonymous';
			
			img.onload = function() {
				clearTimeout(timeoutId);
				try {
					var canvas = document.createElement('canvas');
					canvas.width = img.naturalWidth;
					canvas.height = img.naturalHeight;
					var ctx = canvas.getContext('2d');
					ctx.drawImage(img, 0, 0);
					canvas.toBlob(function(blob) {
						if (blob) {
							setCachedImage(src, blob);
						}
						resolve(src);
					}, 'image/webp', 0.85);
				} catch (e) {
					resolve(src);
				}
			};
			
			img.onerror = function() {
				clearTimeout(timeoutId);
				if (retryNum < MAX_RETRIES) {
					console.warn('[Banner] Image error, retrying:', retryNum + 1, src);
					setTimeout(function() {
						loadImageWithRetry(src, retryNum + 1).then(resolve).catch(reject);
					}, RETRY_DELAY * (retryNum + 1));
				} else {
					reject(new Error('Image load failed after ' + MAX_RETRIES + ' retries'));
				}
			};
			
			img.src = src;
		});
	}

	function createImageElement(src, type, index) {
		var img = document.createElement('img');
		img.alt = type + ' banner image ' + (index + 1);
		img.className = 'object-cover h-full w-full';
		img.src = src;
		img.loading = index === 0 ? 'eager' : 'lazy';
		img.fetchPriority = index === 0 ? 'high' : 'low';
		img.dataset.position = position;
		img.style.objectPosition = position;
		img.decoding = index === 0 ? 'sync' : 'async';
		return img;
	}

	function createImageSlot(type, index, imgSrc) {
		var slot = document.createElement('div');
		slot.className = type === 'mobile' 
			? 'banner-image-slot-mobile absolute inset-0 block md:hidden'
			: 'banner-image-slot-desktop absolute inset-0 hidden md:block';
		slot.dataset.index = index;
		
		var img = createImageElement(imgSrc, type, index);
		slot.appendChild(img);
		
		return slot;
	}

	async function preloadImages(urls, type) {
		var total = urls.length;
		var loaded = 0;
		
		var promises = urls.map(async function(url, index) {
			try {
				await loadImageWithRetry(url);
				loadedImages[type][index] = true;
				loaded++;
				updateLoadingStatus('预加载图片', loaded + '/' + total);
				return { success: true, src: url, index: index };
			} catch (error) {
				loadedImages[type][index] = false;
				loaded++;
				return { success: false, src: url, index: index, error: error };
			}
		});
		
		return Promise.all(promises);
	}

	async function showFirstImage() {
		var type = isMobile() ? 'mobile' : 'desktop';
		var images = type === 'mobile' ? mobileImages : desktopImages;
		
		if (images.length === 0) {
			hideSkeleton();
			showSkeletonError('暂无图片资源', true);
			return;
		}

		updateLoadingStatus('加载首张图片...', '');

		try {
			await loadImageWithRetry(images[0]);
			
			var slot = createImageSlot(type, 0, images[0]);
			var img = slot.querySelector('img');
			
			if (img.complete) {
				slot.style.opacity = '1';
				hideSkeleton();
				container.appendChild(slot);
				if (isCarouselEnabled) {
					slot.classList.add('banner-kb');
				}
			} else {
				img.onload = function() {
					slot.style.opacity = '1';
					hideSkeleton();
					if (isCarouselEnabled) {
						slot.classList.add('banner-kb');
					}
				};
				img.onerror = function() {
					console.warn('[Banner] First image display failed');
					hideSkeleton();
					showSkeletonError('图片显示失败', true);
				};
				container.appendChild(slot);
			}
		} catch (error) {
			console.error('[Banner] Failed to load first image:', error);
			hideSkeleton();
			showSkeletonError('图片加载失败，请检查网络', true);
		}
	}

	function crossfadeToIndex(type, targetIndex) {
		var images = type === 'mobile' ? mobileImages : desktopImages;
		if (images.length <= 1) return;
		if (isCrossfading[type]) return;
		if (targetIndex >= images.length) targetIndex = 0;
		if (targetIndex < 0) targetIndex = images.length - 1;

		var slotClass = type === 'mobile' 
			? 'banner-image-slot-mobile' 
			: 'banner-image-slot-desktop';
		
		var oldSlot = container.querySelector('.' + slotClass);
		if (!oldSlot) return;

		isCrossfading[type] = true;
		currentIndex[type] = targetIndex;

		var newSlot = createImageSlot(type, targetIndex, images[targetIndex]);
		newSlot.style.opacity = '0';
		newSlot.style.zIndex = '2';

		var img = newSlot.querySelector('img');
		if (img && isCarouselEnabled) {
			img.classList.add('banner-kb');
		}

		oldSlot.style.zIndex = '1';
		oldSlot.style.opacity = '1';
		container.appendChild(newSlot);

		void newSlot.offsetWidth;

		newSlot.style.transition = 'opacity ' + FADE_MS + 'ms ease-in-out';
		newSlot.style.opacity = '1';

		oldSlot.style.transition = 'opacity ' + FADE_MS + 'ms ease-in-out';
		oldSlot.style.opacity = '0';

		setTimeout(function() {
			if (oldSlot.parentNode) {
				oldSlot.parentNode.removeChild(oldSlot);
			}
			isCrossfading[type] = false;
		}, FADE_MS);
	}

	function advanceCarousel() {
		var type = isMobile() ? 'mobile' : 'desktop';
		var images = type === 'mobile' ? mobileImages : desktopImages;
		
		if (images.length > 1) {
			var nextIndex = (currentIndex[type] + 1) % images.length;
			crossfadeToIndex(type, nextIndex);
		}
	}

	function startCarousel() {
		if (!isCarouselEnabled) return;
		
		if (carouselTimer) {
			clearInterval(carouselTimer);
		}
		
		carouselTimer = setInterval(advanceCarousel, interval);
	}

	var touchStartX = 0;
	var touchEndX = 0;

	function handleTouchStart(e) {
		touchStartX = e.touches[0].clientX;
	}

	function handleTouchEnd(e) {
		touchEndX = e.changedTouches[0].clientX;
		handleSwipe();
	}

	function handleSwipe() {
		var diff = touchStartX - touchEndX;
		if (Math.abs(diff) > 50) {
			var type = isMobile() ? 'mobile' : 'desktop';
			var images = type === 'mobile' ? mobileImages : desktopImages;
			
			if (images.length > 1) {
				var nextIndex = diff > 0
					? (currentIndex[type] + 1) % images.length
					: (currentIndex[type] - 1 + images.length) % images.length;
				crossfadeToIndex(type, nextIndex);
			}
		}
	}

	function checkNetworkStatus() {
		if (navigator.connection) {
			var connection = navigator.connection;
			var slowConnection = connection.effectiveType === '2g' || connection.effectiveType === 'slow-2g';
			var saveData = connection.saveData;
			
			if (slowConnection || saveData) {
				console.log('[Banner] Slow network detected, optimizing loading');
				LOAD_TIMEOUT = 30000;
				return true;
			}
		}
		return false;
	}

	async function fetchBannerImages() {
		var imageCount = 6;
		var isSlowNetwork = checkNetworkStatus();
		
		if (isSlowNetwork) {
			updateLoadingStatus('检测到慢速网络，优化加载中...', '');
		}
		
		try {
			var controller = new AbortController();
			var timeoutId = setTimeout(function() {
				controller.abort();
			}, 10000);

			var desktopResponse = await fetch('/api/banner-images.json?count=' + imageCount + '&type=desktop', {
				signal: controller.signal
			});
			var mobileResponse = await fetch('/api/banner-images.json?count=' + imageCount + '&type=mobile', {
				signal: controller.signal
			});
			
			clearTimeout(timeoutId);
			
			if (desktopResponse.ok && mobileResponse.ok) {
				var desktopData = await desktopResponse.json();
				var mobileData = await mobileResponse.json();
				
				if (desktopData.images && desktopData.images.length > 0) {
					desktopImages = desktopData.images;
				}
				if (mobileData.images && mobileData.images.length > 0) {
					mobileImages = mobileData.images;
				}
			} else {
				throw new Error('API response not ok');
			}
		} catch (error) {
			console.warn('[Banner] Failed to fetch from API, using fallback:', error);
			desktopImages = Array.isArray(fallbackDesktopImages) ? fallbackDesktopImages : [fallbackDesktopImages];
			mobileImages = Array.isArray(fallbackMobileImages) ? fallbackMobileImages : [fallbackMobileImages];
		}

		if (desktopImages.length === 0 && Array.isArray(fallbackDesktopImages)) {
			desktopImages = fallbackDesktopImages;
		}
		if (mobileImages.length === 0 && Array.isArray(fallbackMobileImages)) {
			mobileImages = fallbackMobileImages;
		}

		await showFirstImage();
		
		if (isCarouselEnabled && (desktopImages.length > 1 || mobileImages.length > 1)) {
			preloadImages(desktopImages.slice(1), 'desktop');
			preloadImages(mobileImages.slice(1), 'mobile');
			startCarousel();
		}

		container.addEventListener('touchstart', handleTouchStart, { passive: true });
		container.addEventListener('touchend', handleTouchEnd, { passive: true });
	}

	if (window.__bannerCarouselCleanup) {
		window.__bannerCarouselCleanup();
		window.__bannerCarouselCleanup = null;
	}

	window.__bannerCarouselCleanup = function() {
		if (carouselTimer) {
			clearInterval(carouselTimer);
		}
		container.removeEventListener('touchstart', handleTouchStart);
		container.removeEventListener('touchend', handleTouchEnd);
		imageCache.clear();
	};

	fetchBannerImages();
})();
</script>

<style>
	.banner-title {
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
		animation: fadeInUp 1s ease-out;
		font-weight: bold;
	}

	.banner-subtitle {
		text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.6);
		animation: fadeInUp 1s ease-out 0.3s both;
		min-height: 1.5em;
		line-height: 1.2;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.banner-skeleton {
		background: linear-gradient(
			90deg,
			var(--card-bg) 0%,
			var(--btn-hover-bg, rgba(0, 0, 0, 0.05)) 50%,
			var(--card-bg) 100%
		);
		background-size: 200% 100%;
		animation: bannerShimmer 1.5s ease-in-out infinite;
		transition: opacity 0.5s ease;
	}

	@keyframes bannerShimmer {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	:global(.dark) .banner-skeleton {
		background: linear-gradient(
			90deg,
			var(--card-bg) 0%,
			rgba(255, 255, 255, 0.05) 50%,
			var(--card-bg) 100%
		);
		background-size: 200% 100%;
	}

	.banner-loading-text {
		z-index: 1;
	}

	.banner-spinner {
		width: 32px;
		height: 32px;
		border: 3px solid rgba(255, 255, 255, 0.2);
		border-top-color: rgba(255, 255, 255, 0.8);
		border-radius: 50%;
		animation: bannerSpin 1s linear infinite;
	}

	@keyframes bannerSpin {
		to {
			transform: rotate(360deg);
		}
	}
</style>
